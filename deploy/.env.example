# Required: PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://viewviet_user:your_password@localhost:5432/viewviet

# Required: Secret key for session cookies (use a long random string)
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Server port (keep 8080 to match nginx config)
PORT=8080

# Environment
NODE_ENV=production
