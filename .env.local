# ViewViet 本地开发环境配置

# 数据库连接
DATABASE_URL=postgresql://viewviet_user:viewviet_password_123@localhost:5432/viewviet

# Session 密钥（本地开发用）
SESSION_SECRET=local_development_secret_key_change_in_production_at_least_32_chars

# 服务器配置
PORT=8080
NODE_ENV=development

# OpenAI API 配置（用于口译功能）
# 注意：需要替换为实际的 API 密钥
OPENAI_API_KEY=sk_test_your_key_here

# Redis 配置（可选，用于会话存储）
REDIS_URL=redis://localhost:6379

# 前端 API 地址（前端连接后端用）
VITE_API_URL=http://localhost:8080
